# ==========================================
# 🦞 PyClaw 配置文件示例
# ==========================================
# 复制此文件为 .env 并填入你的配置
# .env 文件已在 .gitignore 中，不会提交到 GitHub

# ==========================================
# 🔑 API 配置（必须设置）
# ==========================================

# API 密钥
PYCLAW_API_KEY=your_api_key_here

# API 地址（兼容所有 OpenAI 格式的 API）
PYCLAW_BASE_URL=https://api.deepseek.com/v1

# 模型名称
PYCLAW_MODEL=deepseek-chat

# ==========================================
# 🎯 常用模型配置参考
# ==========================================

# ── DeepSeek（默认推荐） ──
# PYCLAW_BASE_URL=https://api.deepseek.com/v1
# PYCLAW_MODEL=deepseek-chat
# PYCLAW_MODEL=deepseek-reasoner

# ── 火山引擎（豆包） ──
# PYCLAW_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# PYCLAW_MODEL=doubao-seed-1-8-251228

# ── 智谱 AI ──
# PYCLAW_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# PYCLAW_MODEL=glm-4-flash

# ── OpenAI ──
# PYCLAW_BASE_URL=https://api.openai.com/v1
# PYCLAW_MODEL=gpt-3.5-turbo

# ── 通义千问 ──
# PYCLAW_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# PYCLAW_MODEL=qwen-turbo

# ==========================================
# 📁 其他配置（可选）
# ==========================================

# 服务端口（默认 2469）
# PORT=2469

# 监听地址（默认 0.0.0.0）
# HOST=0.0.0.0
