# ==========================================
# 🦞 PyClaw 配置文件示例
# ==========================================
# 复制此文件为 pyclaw.json 并填入你的配置
# pyclaw.json 已在 .gitignore 中，不会提交到 GitHub

{
  "API_KEY": "your-api-key-here",
  "SUB_AGENTS": [
    "exec",
    "file"
  ],
  "SUB_AGENTS_ENABLED": true,
  "LANGUAGE": "zh-CN",
  "PROVIDER": "opencode-zen",
  "MODEL": "deepseek-v4-flash-free",
  "PORT": 2469,
  "ENDPOINT": "https://opencode.ai/zen/v1"
}

